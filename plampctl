#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
install_script="${script_dir}/deploy/bootstrap/install-plamp.sh"

usage() {
  cat <<'USAGE'
Usage: ./plampctl [status|logs|restart|upgrade|reinstall|remote-install|set-hostname] [args...]

Without an action, prompts interactively.

Actions:
  status                   Show systemd service state and HTTP readiness
  logs [--lines N] [--follow]
                           Show recent plamp-web journal lines (default 100)
  restart                  Restart plamp-web and wait for HTTP readiness
  upgrade [BRANCH]         Pull latest code from origin/BRANCH (default main), sync Python deps, and restart
  reinstall [options...]   Run deploy/bootstrap/install-plamp.sh with --plamp-dir set to this repo root
  remote-install HOST REMOTE_DIR [options...]
                           Copy deploy/bootstrap/install-plamp.sh to HOST and run it there with --plamp-dir REMOTE_DIR
  set-hostname NAME        Set the local hostname, update /etc/hosts, restart avahi-daemon, and verify NAME.local

Examples:
  ./plampctl
  ./plampctl status
  ./plampctl logs --follow
  ./plampctl restart
  ./plampctl upgrade
  ./plampctl upgrade feature-timer-visibility-modes
  ./plampctl reinstall --public
  ./plampctl reinstall --update-os --enable-heartbeat
  ./plampctl remote-install hugo@sprout ~/plamp --public
  ./plampctl set-hostname tower

Help:
  ./plampctl -h

Unix equivalents:
  systemctl is-active plamp-web
  journalctl -u plamp-web -n 100 --no-pager
  curl -fsS http://127.0.0.1:8000/
USAGE
}

health_url="${PLAMP_HEALTH_URL:-http://127.0.0.1:8000/}"

print_command() {
  printf '+'
  printf ' %q' "$@"
  printf '\n'
}

run_command() {
  print_command "$@"
  "$@"
}

check_http() {
  curl -fsS --max-time 1 "${health_url}" >/dev/null 2>&1
}

wait_for_http() {
  local attempt
  print_command curl -fsS --max-time 1 "${health_url}"
  for attempt in {1..60}; do
    if check_http; then
      echo "HTTP: OK (${health_url})"
      return 0
    fi
    sleep 0.25
  done
  echo "HTTP: unavailable after 15 seconds (${health_url})" >&2
  return 1
}

status_plamp() {
  local service_state
  print_command systemctl is-active plamp-web
  service_state="$(systemctl is-active plamp-web 2>/dev/null || true)"
  echo "service: ${service_state:-unknown}"
  [[ "${service_state}" == "active" ]] || return 1

  print_command curl -fsS --max-time 1 "${health_url}"
  if check_http; then
    echo "HTTP: OK (${health_url})"
  else
    echo "HTTP: unavailable (${health_url})" >&2
    return 1
  fi
}

logs_plamp() {
  local lines=100
  local follow=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --lines)
        [[ $# -ge 2 && "$2" =~ ^[1-9][0-9]*$ ]] || {
          echo "--lines requires a positive integer." >&2
          exit 2
        }
        lines="$2"
        shift 2
        ;;
      --follow|-f)
        follow=1
        shift
        ;;
      *)
        echo "unknown logs option: $1" >&2
        exit 2
        ;;
    esac
  done

  local command=(sudo journalctl -u plamp-web -n "${lines}" --no-pager)
  [[ "${follow}" -eq 1 ]] && command+=(-f)
  run_command "${command[@]}"
}

restart_plamp() {
  run_command sudo systemctl restart plamp-web
  wait_for_http
}

upgrade_plamp() {
  if [[ $# -gt 1 ]]; then
    echo "upgrade accepts at most one branch." >&2
    usage >&2
    exit 2
  fi

  local branch="${1:-main}"
  echo "Upgrading Plamp from origin/${branch}"
  git -C "${script_dir}" fetch origin "${branch}"

  local dirty
  dirty="$(git -C "${script_dir}" status --porcelain)"
  if [[ -n "${dirty}" ]]; then
    echo "cannot upgrade with uncommitted changes:" >&2
    printf '%s\n' "${dirty}" >&2
    exit 1
  fi

  local local_commit
  local remote_commit
  local_commit="$(git -C "${script_dir}" rev-parse --verify "${branch}" 2>/dev/null || true)"
  remote_commit="$(git -C "${script_dir}" rev-parse --verify "origin/${branch}")"
  if [[ -n "${local_commit}" && "${local_commit}" == "${remote_commit}" ]]; then
    echo "origin/${branch} is already up to date."
    wait_for_http
    return 0
  fi
  if [[ -n "${local_commit}" ]]; then
    echo "Incoming commits:"
    git -C "${script_dir}" log --format="%h %s" "${local_commit}..origin/${branch}"
  fi

  git -C "${script_dir}" switch "${branch}"
  git -C "${script_dir}" pull --ff-only origin "${branch}"

  if command -v uv >/dev/null 2>&1; then
    uv sync --project "${script_dir}"
  else
    echo "uv not found; skipping Python dependency sync." >&2
  fi

  restart_plamp
}

set_hostname_plamp() {
  if [[ $# -ne 1 ]]; then
    echo "set-hostname requires exactly one hostname." >&2
    usage >&2
    exit 2
  fi

  local hostname="$1"
  if [[ ! "${hostname}" =~ ^[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?$ ]]; then
    echo "invalid hostname: ${hostname}" >&2
    exit 2
  fi

  local hosts_tmp
  hosts_tmp="$(mktemp)"
  trap 'rm -f "${hosts_tmp}"' RETURN
  cp /etc/hosts "${hosts_tmp}"
  if grep -q '^127\.0\.1\.1[[:space:]]' "${hosts_tmp}"; then
    sed -i "s/^127\\.0\\.1\\.1[[:space:]].*/127.0.1.1\t${hostname}/" "${hosts_tmp}"
  else
    printf '127.0.1.1\t%s\n' "${hostname}" >> "${hosts_tmp}"
  fi

  echo "Applying hostname: ${hostname}"
  sudo cp "${hosts_tmp}" /etc/hosts
  sudo hostnamectl set-hostname "${hostname}"
  sudo systemctl restart avahi-daemon
  getent hosts "${hostname}.local"
  echo "Hostname ready: ${hostname}.local"
}

reinstall_plamp() {
  if [[ ! -f "${install_script}" ]]; then
    echo "install script not found: ${install_script}" >&2
    exit 1
  fi
  run_command bash "${install_script}" --plamp-dir "${script_dir}" "$@"
  wait_for_http
}

remote_install_plamp() {
  if [[ $# -lt 2 ]]; then
    echo "remote-install requires HOST and REMOTE_DIR." >&2
    usage >&2
    exit 2
  fi
  if [[ ! -f "${install_script}" ]]; then
    echo "install script not found: ${install_script}" >&2
    exit 1
  fi

  local host="$1"
  local remote_dir="$2"
  shift 2

  local quoted_remote_dir
  quoted_remote_dir="$(printf '%q' "${remote_dir}")"

  local remote_cmd
  remote_cmd="bash -s -- --plamp-dir ${quoted_remote_dir}"
  if [[ $# -gt 0 ]]; then
    local remote_arg
    for remote_arg in "$@"; do
      printf -v remote_cmd '%s %q' "${remote_cmd}" "${remote_arg}"
    done
  fi

  echo "Remote host    : ${host}"
  echo "Remote plamp dir: ${remote_dir}"
  echo "Remote command : ${remote_cmd}"
  ssh "${host}" "${remote_cmd}" < "${install_script}"
}

prompt_action() {
  local reply
  printf 'Choose action: s[t]atus, [l]ogs, [r]estart, [u]pgrade, re[i]nstall, remote-[s]sh install, set-[h]ostname, [c]ancel: '
  read -r reply
  case "${reply}" in
    t|T|status|Status)
      status_plamp
      ;;
    l|L|logs|Logs)
      logs_plamp
      ;;
    r|R|restart|Restart)
      restart_plamp
      ;;
    u|U|upgrade|Upgrade)
      upgrade_plamp
      ;;
    i|I|reinstall|Reinstall)
      reinstall_plamp
      ;;
    s|S|ssh|SSH|remote|Remote|remote-install|Remote-install)
      local host
      local remote_dir
      printf 'SSH host (example hugo@sprout): '
      read -r host
      printf 'Remote plamp dir (example ~/plamp): '
      read -r remote_dir
      remote_install_plamp "${host}" "${remote_dir}"
      ;;
    h|H|hostname|Hostname|set-hostname|Set-hostname)
      local hostname
      printf 'New hostname (example tower): '
      read -r hostname
      set_hostname_plamp "${hostname}"
      ;;
    c|C|cancel|Cancel|"")
      echo "Cancelled."
      ;;
    *)
      echo "unknown choice: ${reply}" >&2
      usage >&2
      exit 2
      ;;
  esac
}

case "${1-}" in
  "")
    prompt_action
    ;;
  -h|--help)
    usage
    ;;
  status)
    shift
    [[ $# -eq 0 ]] || { echo "status does not accept arguments." >&2; exit 2; }
    status_plamp
    ;;
  logs)
    shift
    logs_plamp "$@"
    ;;
  restart)
    shift
    if [[ $# -gt 0 ]]; then
      echo "restart does not accept extra arguments." >&2
      usage >&2
      exit 2
    fi
    restart_plamp
    ;;
  upgrade)
    shift
    upgrade_plamp "$@"
    ;;
  reinstall)
    shift
    reinstall_plamp "$@"
    ;;
  remote-install)
    shift
    remote_install_plamp "$@"
    ;;
  set-hostname)
    shift
    set_hostname_plamp "$@"
    ;;
  *)
    echo "unknown action: $1" >&2
    usage >&2
    exit 2
    ;;
esac
