# Python cache artifacts
__pycache__/
*.py[cod]

# Local Python virtual environments
.venv/

# Local runtime data owned by the host API
data/

# Local Pico scheduler state used for host-side deploys
pico_scheduler/state.json

# Generated 3D outputs / docs
things/plamp_stand/doc/*
!things/plamp_stand/doc/stand.jpg
things/plamp_stand/prints/

# Runtime grow data (tracked grow.json files live alongside these)
grow/grows/*/captures/
grow/grows/*/events.jsonl
grow/grows/*/summaries/
grow/grows/*/predictions/
grow/grows/*/amendments/
grow/cron-capture.log
