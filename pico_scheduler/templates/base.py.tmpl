import os
import select
import sys
import time
import ujson as json
from machine import Pin, PWM

FIRMWARE_NAME = "pico_scheduler"
FIRMWARE_REVISION = {firmware_revision}
FIRMWARE_PROTOCOL = {firmware_protocol}
STATE_PATHS = ("/plamp_state_a.json", "/plamp_state_b.json")
MAX_COMMAND_BYTES = 16384
LOOP_SLEEP_MS = {loop_sleep_ms}
PWM_FREQ = {pwm_freq}

devices = []
active_generation = 0
active_state_path = None
command_buffer = ""
command_overflow = False


def _integer(value, label, minimum, maximum=None):
    if isinstance(value, bool) or not isinstance(value, int) or value < minimum:
        raise ValueError("%s must be an integer >= %s" % (label, minimum))
    if maximum is not None and value > maximum:
        raise ValueError("%s must be <= %s" % (label, maximum))
    return value


def normalize_state(raw):
    if not isinstance(raw, dict) or set(raw) != {{"devices"}}:
        raise ValueError("scheduler state must contain only devices")
    if not isinstance(raw["devices"], list):
        raise ValueError("devices must be a list")
    normalized = []
    ids = set()
    pins = set()
    for index, source in enumerate(raw["devices"]):
        if not isinstance(source, dict):
            raise ValueError("device %s must be an object" % index)
        allowed = {{"id", "type", "pin", "current_t", "reschedule", "pattern"}}
        required = {{"type", "pin", "current_t", "reschedule", "pattern"}}
        if set(source) - allowed or not required <= set(source):
            raise ValueError("device %s has invalid fields" % index)
        device_type = source["type"]
        if device_type not in ("gpio", "pwm"):
            raise ValueError("device %s has unsupported type: %s" % (index, device_type))
        pin = _integer(source["pin"], "device %s pin" % index, 0, 29)
        if pin in pins:
            raise ValueError("duplicate pin: %s" % pin)
        pins.add(pin)
        device_id = source.get("id")
        if device_id is not None:
            if not isinstance(device_id, str) or not device_id:
                raise ValueError("device %s id must be a non-empty string" % index)
            if device_id in ids:
                raise ValueError("duplicate device id: %s" % device_id)
            ids.add(device_id)
        current_t = _integer(source["current_t"], "device %s current_t" % index, 0)
        reschedule = _integer(source["reschedule"], "device %s reschedule" % index, 0, 1)
        source_pattern = source["pattern"]
        if not isinstance(source_pattern, list) or not source_pattern:
            raise ValueError("device %s pattern must be a non-empty list" % index)
        pattern = []
        for step_index, source_step in enumerate(source_pattern):
            if not isinstance(source_step, dict) or set(source_step) != {{"val", "dur"}}:
                raise ValueError("device %s pattern %s must contain val and dur" % (index, step_index))
            value_max = 1 if device_type == "gpio" else 65535
            value = _integer(source_step["val"], "device %s pattern %s val" % (index, step_index), 0, value_max)
            duration = _integer(source_step["dur"], "device %s pattern %s dur" % (index, step_index), 1)
            pattern.append({{"val": value, "dur": duration}})
        item = {{
            "type": device_type,
            "pin": pin,
            "current_t": current_t,
            "reschedule": reschedule,
            "pattern": pattern,
        }}
        if device_id is not None:
            item["id"] = device_id
        normalized.append(item)
    return {{"devices": normalized}}


def validate_stored_state(raw):
    if not isinstance(raw, dict) or set(raw) != {{"generation", "devices"}}:
        raise ValueError("stored state has invalid fields")
    generation = _integer(raw["generation"], "generation", 0)
    normalized = normalize_state({{"devices": raw["devices"]}})
    return {{"generation": generation, "devices": normalized["devices"]}}


def load_state():
    selected = None
    selected_path = None
    for path in STATE_PATHS:
        try:
            handle = open(path, "r")
            try:
                candidate = validate_stored_state(json.loads(handle.read()))
            finally:
                handle.close()
        except Exception:
            continue
        if selected is None or candidate["generation"] > selected["generation"]:
            selected = candidate
            selected_path = path
    if selected is None:
        return {{"generation": 0, "devices": []}}, None
    return selected, selected_path


def persist_state(state):
    global active_generation, active_state_path
    target_path = STATE_PATHS[1] if active_state_path == STATE_PATHS[0] else STATE_PATHS[0]
    document = {{
        "generation": active_generation + 1,
        "devices": state["devices"],
    }}
    handle = open(target_path, "w")
    try:
        handle.write(json.dumps(document))
        handle.flush()
    finally:
        handle.close()
    os.sync()
    active_generation = document["generation"]
    active_state_path = target_path
    return document


def build_outputs(state):
    built = []
    for source in state["devices"]:
        output = None
        for active in devices:
            if (not active.get("overlay") and active["type"] == source["type"]
                    and active["pin"] == source["pin"]):
                output = active["output"]
                break
        if output is None:
            if source["type"] == "gpio":
                output = Pin(source["pin"], Pin.OUT)
            else:
                output = PWM(Pin(source["pin"]))
                output.freq(PWM_FREQ)
        device = {{
            "type": source["type"],
            "pin": source["pin"],
            "overlay": False,
            "elapsed_t": source["current_t"],
            "reschedule": source["reschedule"],
            "pattern": source["pattern"],
            "total_t": sum(step["dur"] for step in source["pattern"]),
            "output": output,
            "last_value": None,
        }}
        if "id" in source:
            device["id"] = source["id"]
        built.append(device)
    return built


def retire_output(device):
    if device["type"] == "gpio":
        device["output"].value(0)
        return
    device["output"].duty_u16(0)
    deinit = getattr(device["output"], "deinit", None)
    if deinit is not None:
        deinit()


def replace_devices(replacement):
    global devices
    overlays = [device for device in devices if device.get("overlay")]
    for device in devices:
        if not device.get("overlay"):
            reused = any(candidate["output"] is device["output"] for candidate in replacement)
            overlay_uses = any(overlay["output"] is device["output"] for overlay in overlays)
            if not reused and not overlay_uses:
                retire_output(device)
    replacement_by_pin = {{device["pin"]: device for device in replacement}}
    for overlay in overlays:
        base = replacement_by_pin.get(overlay["pin"])
        if base is not None:
            overlay["output"] = base["output"]
    devices = replacement + overlays


def error(message, command=None):
    if command is None:
        content = message
    else:
        content = {{"command": command, "message": message}}
    print(json.dumps({{"type": "error", "content": content}}))
    return False


def report_item(device, current_value=None):
    item = {{
            "type": device["type"],
            "pin": device["pin"],
            "elapsed_t": device["elapsed_t"],
            "cycle_t": device["elapsed_t"] % device["total_t"] if device["reschedule"] else device["elapsed_t"],
            "reschedule": device["reschedule"],
            "pattern": device["pattern"],
            "current_value": device["last_value"] if current_value is None else current_value,
    }}
    if "id" in device:
        item["id"] = device["id"]
    return item


def report():
    base_devices = [device for device in devices if not device.get("overlay")]
    overlays = [device for device in devices if device.get("overlay")]
    out = []
    for device in base_devices:
        overlay_value = None
        for overlay in overlays:
            if overlay["pin"] == device["pin"]:
                overlay_value = overlay["last_value"]
        out.append(report_item(device, overlay_value))
    overlay_out = [report_item(overlay) for overlay in overlays]
    firmware = {{
        "name": FIRMWARE_NAME,
        "revision": FIRMWARE_REVISION,
        "protocol": FIRMWARE_PROTOCOL,
    }}
    content = {{"firmware": firmware, "devices": out, "overlays": overlay_out}}
    print(json.dumps({{"type": "report", "content": content}}))


def apply():
    changed = False
    for device in devices:
        cycle_t = device["elapsed_t"] % device["total_t"] if device["reschedule"] else device["elapsed_t"]
        elapsed = 0
        value = device["pattern"][-1]["val"]
        for step in device["pattern"]:
            elapsed += step["dur"]
            if cycle_t < elapsed:
                value = step["val"]
                break
        if device["type"] == "gpio":
            device["output"].value(value)
        else:
            device["output"].duty_u16(value)
        if device["last_value"] != value:
            device["last_value"] = value
            changed = True
    return changed


def configure(content):
    try:
        normalized = normalize_state(content)
        proposed_types = {{device["pin"]: device["type"] for device in normalized["devices"]}}
        for device in devices:
            if device.get("overlay") and proposed_types.get(device["pin"], "gpio") != "gpio":
                raise ValueError("cannot change active pulse pin %s from gpio to pwm" % device["pin"])
        persist_state(normalized)
        replacement = build_outputs(normalized)
        replace_devices(replacement)
        apply()
        report()
        return True
    except Exception as exc:
        return error(str(exc), "configure")


def handle_message(message):
    if isinstance(message, dict) and "type" in message and message["type"] == "configure":
        return configure(message.get("content"))
    return error("unknown command")


def device_for_pin(pin):
    for device in devices:
        if device["pin"] == pin and device["type"] == "gpio" and not device.get("overlay"):
            return device
    return None


def pulse_device(device, seconds):
    pulse = {{
        "type": "gpio",
        "pin": device["pin"],
        "overlay": True,
        "elapsed_t": 0,
        "reschedule": 0,
        "pattern": [{{"val": 1, "dur": seconds}}],
        "total_t": seconds,
        "output": device["output"],
        "last_value": None,
    }}
    devices.append(pulse)
    apply()
    report()
    return True


def handle_command(line):
    line = line.strip()
    if not line:
        return
    if line == "r":
        report()
        return
    parts = line.split()
    if parts[0] == "p" and len(parts) == 3:
        try:
            pin = int(parts[1])
            seconds = int(parts[2])
        except Exception:
            error("invalid pulse command")
            return
        if seconds <= 0:
            error("pulse seconds must be > 0")
            return
        device = device_for_pin(pin)
        if device is None:
            error("unknown pulse pin")
            return
        if device["output"].value() == 1:
            error("pulse pin is already on")
            return
        pulse_device(device, seconds)
        return
    try:
        message = json.loads(line)
    except Exception:
        error("unknown command")
        return
    handle_message(message)


poller = select.poll()
command_input = sys.stdin
poller.register(command_input, select.POLLIN)


def read_commands():
    global command_buffer, command_overflow
    while poller.poll(0):
        char = command_input.read(1)
        if not char:
            return
        if char == "\r":
            continue
        if char == "\n":
            if command_overflow:
                command_overflow = False
                command_buffer = ""
                continue
            line = command_buffer
            command_buffer = ""
            handle_command(line)
        elif not command_overflow:
            command_buffer += char
            if len(command_buffer) > MAX_COMMAND_BYTES:
                command_buffer = ""
                command_overflow = True
                error("command too long")


def tick(dt):
    if dt <= 0:
        return
    remove = []
    for device in devices:
        device["elapsed_t"] += dt
        if not device["reschedule"] and device["elapsed_t"] >= device["total_t"]:
            remove.append(device)
    if remove:
        for device in remove:
            devices.remove(device)
        for device in remove:
            if device.get("overlay") and not any(active["pin"] == device["pin"] for active in devices):
                retire_output(device)
        apply()


def initialize():
    global active_generation, active_state_path
    stored, path = load_state()
    active_generation = stored["generation"]
    active_state_path = path
    replace_devices(build_outputs({{"devices": stored["devices"]}}))
    apply()


def main():
    last_tick_ms = time.ticks_ms()
    accum_ms = 0
    while True:
        read_commands()
        now_ms = time.ticks_ms()
        delta_ms = time.ticks_diff(now_ms, last_tick_ms)
        last_tick_ms = now_ms
        if delta_ms > 0:
            accum_ms += delta_ms
            dt = accum_ms // 1000
            if dt:
                accum_ms -= dt * 1000
                tick(dt)
                apply()
        time.sleep_ms(LOOP_SLEEP_MS)


initialize()

if __name__ == "__main__":
    main()
