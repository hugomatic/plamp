import select
import sys
import time
import ujson as json
{machine_import}

LOOP_SLEEP_MS = {loop_sleep_ms}
{pwm_helper}
{device_assignments}

poller = select.poll()
poller.register(sys.stdin, select.POLLIN)
command_buffer = ""

def error(message):
    print(json.dumps({{"type": "error", "content": message}}))
    return False


def report():
    out = []
    for device in devices:
        item = {{
            "type": device["type"],
            "pin": device["pin"],
            "elapsed_t": device["elapsed_t"],
            "cycle_t": device["elapsed_t"] % device["total_t"] if device["reschedule"] else device["elapsed_t"],
            "reschedule": device["reschedule"],
            "pattern": device["pattern"],
        }}
        item["current_value"] = device["last_value"]
        if "id" in device:
            item["id"] = device["id"]
        out.append(item)
    print(json.dumps({{"type": "report", "content": {{"devices": out}}}}))


def device_for_pin(pin):
    for device in devices:
        if device["pin"] == pin and device["type"] == "gpio":
            return device
    return None


def pulse_device(device, seconds):
    pulse = {{
        "type": "gpio",
        "pin": device["pin"],
        "elapsed_t": 0,
        "reschedule": 0,
        "pattern": [{{"val": 1, "dur": seconds}}],
        "total_t": seconds,
        "output": device["output"],
        "last_value": None,
    }}
    devices.append(pulse)
    apply()
    report()
    return True


def handle_command(line):
    line = line.strip()
    if not line:
        return
    if line == "r":
        report()
        return
    parts = line.split()
    if parts[0] == "p" and len(parts) == 3:
        try:
            pin = int(parts[1])
            seconds = int(parts[2])
        except:
            error("invalid pulse command")
            return
        if seconds <= 0:
            error("pulse seconds must be > 0")
            return
        device = device_for_pin(pin)
        if device is None:
            error("unknown pulse pin")
            return
        if device["output"].value() == 1:
            error("pulse pin is already on")
            return
        pulse_device(device, seconds)
        return
    error("unknown command")


def read_commands():
    global command_buffer
    while poller.poll(0):
        char = sys.stdin.read(1)
        if not char:
            return
        if char == "\r":
            continue
        if char == "\n":
            line = command_buffer
            command_buffer = ""
            handle_command(line)
        else:
            command_buffer += char
            if len(command_buffer) > 80:
                command_buffer = ""
                error("command too long")


def tick(dt):
    if dt <= 0:
        return

    remove = []
    for device in devices:
        device["elapsed_t"] += dt
        if not device["reschedule"] and device["elapsed_t"] >= device["total_t"]:
            remove.append(device)

    if remove:
        for device in remove:
            devices.remove(device)
        apply()


def apply():
    changed = False

    for device in devices:
        cycle_t = device["elapsed_t"] % device["total_t"] if device["reschedule"] else device["elapsed_t"]
        elapsed = 0
        value = device["pattern"][-1]["val"]

        for step in device["pattern"]:
            elapsed += step["dur"]
            if cycle_t < elapsed:
                value = step["val"]
                break

        if device["type"] == "gpio":
            device["output"].value(value)
        else:
            device["output"].duty_u16(value)

        if device["last_value"] != value:
            device["last_value"] = value
            changed = True

    return changed


def main():
    apply()

    last_tick_ms = time.ticks_ms()
    accum_ms = 0

    while True:
        read_commands()
        now_ms = time.ticks_ms()
        delta_ms = time.ticks_diff(now_ms, last_tick_ms)
        last_tick_ms = now_ms

        if delta_ms > 0:
            accum_ms += delta_ms
            dt = accum_ms // 1000
            if dt:
                accum_ms -= dt * 1000
                tick(dt)
                apply()

        time.sleep_ms(LOOP_SLEEP_MS)


if __name__ == "__main__":
    main()
